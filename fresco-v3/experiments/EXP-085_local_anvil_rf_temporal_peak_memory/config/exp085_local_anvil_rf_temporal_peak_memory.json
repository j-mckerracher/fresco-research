{
  "run_id": "EXP-085_local_anvil_rf_temporal_peak_memory",
  "description": "Local telemetry blueprint: intra-cluster Random Forest temporal prediction of peak_memory_gb on the full Anvil dataset using the authoritative v3 production parquet.",

  "dataset_version": "v3.0",
  "dataset_label": "chunks-v3-authoritative",
  "input_root": "<FRESCO_DATA_ROOT>/chunks-v3",
  "inputs_manifest": "<FRESCO_DATA_ROOT>/chunks-v3/manifests/output_manifest.jsonl",
  "output_root": "<FRESCO_V3_CODE_ROOT>/experiments/EXP-085_local_anvil_rf_temporal_peak_memory",

  "clusters": ["anvil"],
  "date_range": {"start": "2015-01-01", "end": "2023-12-31"},

  "source_cluster": "anvil",
  "regime": "hardware_cpu_standard",

  "label_column": "peak_memory_gb",
  "label_transform": "log1p",
  "label_proxy": false,

  "feature_columns": "all_numeric",
  "feature_transform": "log1p",

  "leakage_columns": [
    "memory_original_value", "memory_original_unit",
    "peak_memory_fraction", "memory_includes_cache",
    "memory_collection_method", "memory_aggregation",
    "memory_sampling_interval_sec"
  ],
  "id_columns": [
    "jid", "jid_global", "cluster", "queue", "partition",
    "host", "node_type", "gpu_model"
  ],
  "temporal_columns": [
    "submit_time", "start_time", "end_time", "time"
  ],

  "model": {
    "type": "random_forest",
    "n_estimators": 100,
    "max_depth": 20,
    "min_samples_leaf": 4,
    "n_jobs": -1,
    "random_state": 42
  },

  "split": {
    "type": "temporal",
    "test_frac": 0.2,
    "sort_column": "submit_time"
  },

  "imputer": {
    "strategy": "median"
  },

  "max_rows_source": null,
  "sample_n_row_groups_per_file": null,
  "random_seed": 42,
  "n_boot": 200,

  "write_manifests": true,
  "write_validation_reports": true,
  "validation_level": "strict"
}
